    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "@types/node-fetch": "^2.6.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  }
